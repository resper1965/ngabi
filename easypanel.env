# =============================================================================
# DOMAIN CONFIGURATION
# =============================================================================
DOMAIN=ngabi.ness.tec.br
API_DOMAIN=api.ngabi.ness.tec.br
ADMIN_EMAIL=admin@ngabi.ness.tec.br

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=redis://ngabi-redis:6379
REDIS_PASSWORD=

# =============================================================================
# POSTGRESQL CONFIGURATION (OPCIONAL - PARA BACKUP LOCAL)
# =============================================================================
POSTGRES_PASSWORD=ngabi_secure_password_2024
POSTGRES_DB=ngabi_backup
POSTGRES_USER=ngabi_user

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
APP_NAME=n.Gabi
APP_VERSION=2.0.0
NODE_ENV=production

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
CORS_ORIGINS=https://ngabi.ness.tec.br,https://www.ngabi.ness.tec.br,https://api.ngabi.ness.tec.br

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
VITE_API_BASE_URL=https://api.ngabi.ness.tec.br

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================
ENABLE_METRICS=true
ENABLE_HEALTH_CHECKS=true
LOG_LEVEL=INFO

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *  # Diariamente às 2h da manhã

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
ENABLE_RATE_LIMITING=true
ENABLE_CORS=true
ENABLE_SSL=true

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================
REDIS_MAX_MEMORY=256mb
REDIS_MAX_MEMORY_POLICY=allkeys-lru
WORKER_PROCESSES=4 