# =============================================================================
# Variáveis de Ambiente - n.Gabi
# =============================================================================

# =============================================================================
# BACKEND VARIABLES
# =============================================================================

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI Configuration
OPENAI_API_KEY=your-openai-key

# Redis Configuration (EasyPanel)
REDIS_URL=redis://default:password@redis-host:6379
REDIS_HOST=redis-host
REDIS_PORT=6379
REDIS_PASSWORD=password
REDIS_USERNAME=default

# App Configuration
APP_NAME=nGabi
APP_VERSION=1.0.0
ENVIRONMENT=homologacao
DEBUG=false
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_CHAT=200
RATE_LIMIT_AUTH=100
RATE_LIMIT_API=500

# CORS Configuration
CORS_ORIGINS=https://ngabi.ness.tec.br,http://localhost:3000

# =============================================================================
# FRONTEND VARIABLES
# =============================================================================

# API Base URL
VITE_API_BASE_URL=https://ngabi.ness.tec.br/backend

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# OpenAI (para testes diretos)
VITE_OPENAI_API_KEY=your-openai-key

# Environment
NODE_ENV=production

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================

# Backend Docker
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0

# Frontend Docker
FRONTEND_PORT=3000
FRONTEND_HOST=0.0.0.0

# Redis Docker
REDIS_DOCKER_PORT=6379

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================

# EasyPanel Configuration
EASYPANEL_PROJECT_NAME=ngabi-homologacao
EASYPANEL_DOMAIN=ngabi.ness.tec.br

# GitHub Configuration
GITHUB_REPO=https://github.com/seu-usuario/ngabi
GITHUB_BRANCH=main

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================

# Health Check URLs
HEALTH_CHECK_BACKEND=https://ngabi.ness.tec.br/backend/health
HEALTH_CHECK_FRONTEND=https://ngabi.ness.tec.br
HEALTH_CHECK_REDIS=https://ngabi.ness.tec.br/backend/health/redis

# Logging
LOG_LEVEL_BACKEND=INFO
LOG_LEVEL_FRONTEND=warn

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/Disable Features
FEATURE_CHAT_ENABLED=true
FEATURE_AGENTS_ENABLED=true
FEATURE_LANGCHAIN_ENABLED=true
FEATURE_VOICE_STYLE_ENABLED=true
FEATURE_RAG_ENABLED=true
FEATURE_STREAMING_ENABLED=true
FEATURE_CACHING_ENABLED=true
FEATURE_RATE_LIMITING_ENABLED=true
FEATURE_MONITORING_ENABLED=true

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# JWT Configuration (managed by Supabase)
JWT_SECRET_KEY=your-jwt-secret-key

# CORS Security
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================

# Timeouts
REQUEST_TIMEOUT=30
CHAT_TIMEOUT=60
STREAM_TIMEOUT=300

# Cache Configuration
CACHE_TTL=1800
CACHE_MAX_SIZE=1000

# Rate Limiting
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================

# Test Environment
TEST_ENVIRONMENT=homologacao
TEST_DEBUG=true
TEST_LOG_LEVEL=DEBUG

# Test URLs
TEST_API_URL=https://ngabi.ness.tec.br/backend
TEST_FRONTEND_URL=https://ngabi.ness.tec.br

# =============================================================================
# DOCUMENTATION
# =============================================================================

# Para usar este arquivo:
# 1. Copie para .env
# 2. Substitua os valores pelos reais
# 3. Configure no EasyPanel
# 4. Nunca commite o .env real

# Exemplo de uso:
# cp env.example .env
# nano .env  # Editar com valores reais 